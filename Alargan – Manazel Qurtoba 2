<style>
:root{
  --blue:#1A73E8;
  --blue-soft:#E8F0FE;
  --green:#34A853;
  --yellow:#FBBC05;
  --red:#EA4335;
  --dark:#202124;
  --gray:#5f6368;
}

body{
  margin:0;
  background:#e0e0e0;
  font-family:Segoe UI,Tahoma,Verdana,sans-serif;
  color:var(--dark);
}

.page{
  width:210mm;
  min-height:297mm;
  margin:10mm auto;
  padding:18mm;
  background:#fff;
  box-shadow:0 0 10px rgba(0,0,0,.1);
  position:relative;
  box-sizing:border-box;
  page-break-after:always;
}

.header-wrap{
  background:linear-gradient(90deg,#E8F0FE 0%,#ffffff 75%);
  padding:12px 14px 14px;
  margin:-18mm -18mm 16px;
}

.header-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.brand{
  display:flex;
  align-items:center;
  gap:12px;
}

.brand img{ height:46px; }

.brand-name{
  font-size:17px;
  font-weight:700;
  letter-spacing:0.4px;
}

.header-right{
  font-weight:700;
  color:var(--gray);
}

.header-divider{
  border-bottom:2px solid var(--blue);
  margin:10px 0 8px;
}

.header-title{
  font-size:16px;
  font-weight:800;
  letter-spacing:0.3px;
}

footer{
  position:absolute;
  bottom:14mm;
  left:18mm;
  right:18mm;
  font-size:10px;
  color:var(--gray);
  background:var(--blue-soft);
  border-top:1px solid #d2e3fc;
  padding:8px 10px;
  display:flex;
  justify-content:space-between;
}

.meta{
  font-size:13.5px;
  line-height:1.9;
}

.breakdown h3{
  font-size:15px;
  font-weight:800;
}

.step{
  margin-bottom:10px;
  padding:10px 12px;
  border:1px solid #e6e6e6;
  border-left:5px solid var(--blue);
  background:#fff;
  border-radius:6px;
}

.step strong{
  display:block;
  margin-bottom:4px;
}

table{
  width:100%;
  border-collapse:collapse;
  margin-top:10px;
}

th{
  text-align:left;
  padding:10px;
  background:var(--blue-soft);
  border-bottom:2px solid var(--blue);
  font-size:12.8px;
}

td{
  padding:10px;
  border-bottom:1px solid #eee;
  font-size:12.8px;
  vertical-align:top;
}

.pill{
  padding:4px 10px;
  border-radius:20px;
  font-size:11px;
  font-weight:800;
  color:#fff;
  text-transform:uppercase;
}

.critical{background:var(--red);}
.warning{background:var(--yellow);color:#222;}

/* ✅ ADD-ON START (No core edits — only additions) */
*{ -webkit-print-color-adjust:exact; print-color-adjust:exact; }
body{ -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }

.section{
  font-size:15px;
  font-weight:900;
  margin-top:16px;
}

.summary{
  border:1px solid #d2e3fc;
  background:linear-gradient(180deg,#f7fbff 0%,#ffffff 65%);
  border-left:5px solid var(--green);
  padding:10px 12px;
  border-radius:8px;
  margin:10px 0 14px;
}

.summary .row{
  display:flex;
  gap:12px;
  align-items:flex-start;
}

.badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-weight:900;
  font-size:12px;
  padding:6px 10px;
  border-radius:999px;
  background:#e8f5e9;
  color:#1b5e20;
  white-space:nowrap;
}

.kpi-grid{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:10px;
  margin-top:10px;
}

.kpi{
  border:1px solid #eee;
  background:#fff;
  border-radius:10px;
  padding:10px 10px 12px;
}

.kpi .label{
  font-size:11px;
  color:var(--gray);
  font-weight:700;
  letter-spacing:.2px;
}

.kpi .value{
  font-size:18px;
  font-weight:900;
  margin-top:4px;
}

.progress{
  height:10px;
  background:#eef3fd;
  border-radius:999px;
  overflow:hidden;
  margin-top:8px;
  border:1px solid #dbe7ff;
}

.progress > span{
  display:block;
  height:100%;
  width:87%;
  background:linear-gradient(90deg,var(--blue),#4c8bf5);
}

.note{
  margin-top:8px;
  font-size:11.6px;
  color:var(--gray);
  line-height:1.6;
}

.next-steps{
  margin-top:12px;
  border:1px solid #eee;
  border-radius:10px;
  overflow:hidden;
}

.next-steps .head{
  background:var(--blue-soft);
  border-bottom:1px solid #d2e3fc;
  padding:10px 12px;
  font-weight:900;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.tag{
  font-size:11px;
  font-weight:900;
  padding:5px 10px;
  border-radius:999px;
  background:#fff;
  border:1px solid #d2e3fc;
  color:var(--blue);
}

.next-steps ul{
  margin:0;
  padding:10px 16px 14px 22px;
  line-height:1.7;
  font-size:12.8px;
}

.next-steps li{ margin:6px 0; }

.mini{
  display:inline-block;
  font-size:11px;
  font-weight:900;
  padding:3px 8px;
  border-radius:999px;
  background:#f1f3f4;
  color:#3c4043;
  margin-left:8px;
}

@media print{
  body{ background:#fff; }
  .page{ margin:0; box-shadow:none; }
}
/* ✅ ADD-ON END */
</style>
</head>

